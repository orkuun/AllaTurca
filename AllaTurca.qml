import QtQuick 2.9
import QtQuick.Controls 2.2
import QtQuick.Layouts 1.3
import MuseScore 3.0

MuseScore {
    id: usulPlugin
    menuPath: "Plugins.AllaTurca"
    title: "AllaTurca"
    description: "Partisyona, vuruş desenine göre bir vurmalı partisi ekler."
    thumbnailName: "AllaTurca.png"
    version: "0.6"
    pluginType: "dialog"
    requiresScore: true
    width: 460
    height: 480

    property var dumPattern: [true, false, false, false]
    property var beatValues: [480, 480, 480, 480]

    // Hazır usul şablonları: ad, vuruş deseni (pattern metni), düm/tek dizisi, görsel anahtarı
    property var usulPresets: [
        { name: "2 Zamanlı — Nim Sofyan",          pattern: "d+d",                       dum: [true, false], svgKey: "nim_sofyan" },
        { name: "3 Zamanlı — Semai",               pattern: "d+d+d",                     dum: [true, false, false], svgKey: "semai" },
        { name: "4 Zamanlı — Sofyan",              pattern: "i+d+d",                     dum: [true, true, false], svgKey: "sofyan" },
        { name: "5 Zamanlı — Türk Aksağı (2+3)",   pattern: "d+d+s",                     dum: [true, false, false], svgKey: "turk_aksagi_23" },
        { name: "5 Zamanlı — Türk Aksağı (3+2)",   pattern: "s+d+s+s",                   dum: [true, false, true, false], svgKey: "turk_aksagi_32" },
        { name: "6 Zamanlı — Yürük Semai",         pattern: "s+s+s+s+d",                 dum: [true, false, false, true, false], svgKey: "yuruk_semai" },
        { name: "7 Zamanlı — Devr-i Hindi (3+2+2)",pattern: "s+s+s+d+d",                 dum: [true, false, false, true, false], svgKey: "devri_hindi" },
        { name: "7 Zamanlı — Devr-i Turan (2+2+3)",pattern: "d+d+d.",                    dum: [true, false, false], svgKey: "devri_turan" },
        { name: "8 Zamanlı — Düyek",               pattern: "s+d+s+d+d",                 dum: [true, false, false, true, false], svgKey: "duyek" },
        { name: "8 Zamanlı — Müsemmen",            pattern: "d.+d+d.",                   dum: [true, false, false], svgKey: "musemmen" },
        { name: "9 Zamanlı — Aksak",               pattern: "d+s+s+d+d+s",               dum: [true, true, false, true, false, false], svgKey: "aksak" },
        { name: "9 Zamanlı — Evfer",               pattern: "d+s+s+d+s+d",               dum: [true, true, false, true, false, false], svgKey: "evfer" },
        { name: "9 Zamanlı — Raks Aksağı",         pattern: "d+d.+d+d",                  dum: [true, false, true, false], svgKey: "raks_aksagi" },
        { name: "9 Zamanlı — Oynak",               pattern: "s+s+s+d+d+d",               dum: [true, false, false, true, false, false], svgKey: "oynak" },
        { name: "10 Zamanlı — Aksak Semai",        pattern: "d+s+d+d+d+s",               dum: [true, true, false, true, false, false], svgKey: "aksak_semai" },
        { name: "10 Zamanlı — Curcuna",            pattern: "s+o+s+s+s+o",               dum: [true, true, false, true, false, false], svgKey: "curcuna" },
        { name: "10 Zamanlı — Cengi Harbi",        pattern: "s+s+s+s+s+s+s+s+s+s",       dum: [true, false, true, false, true, false, false, true, false, false], svgKey: "cengi_harbi" },
        { name: "Diğer (Elle Gir)",                pattern: "",                          dum: [], svgKey: "" }
    ]

    // Her usul şablonu için gömülü SVG görseli (base64, vuruş şeması)
    property var usulSvgMap: ({
        "nim_sofyan": "",
        "semai": "",
        "sofyan": "",
        "turk_aksagi_23": "",
        "turk_aksagi_32": "",
        "yuruk_semai": "",
        "devri_hindi": "",
        "devri_turan": "",
        "duyek": "",
        "musemmen": "",
        "aksak": "",
        "evfer": "",
        "raks_aksagi": "",
        "oynak": "",
        "aksak_semai": "",
        "curcuna": "",
        "cengi_harbi": ""
    })
    property int dumPitch: 45  // Open Hi-Hat — kuvvetli vuruş
    property int tekPitch: 41  // Low Floor Tom — hafif vuruş

    // Seçili usul şablonunu (pattern + dum dizisi) ilgili arayüz elemanlarına uygular.
    function applyPreset(idx) {
        var preset = usulPresets[idx]
        if (preset.pattern.length > 0) {
            // Hazır şablon seçildi: deseni ve düm/tek dizisini uygula
            patternInput.text = preset.pattern
            Qt.callLater(function() {
                dumPattern = preset.dum.slice()
                patternRepeater.model = 0
                patternRepeater.model = dumPattern.length
            })
        } else {
            // "Diğer" seçildi: kullanıcı sıfırdan girebilsin diye desen kutusunu
            // ve checkbox satırını temizleyip boşaltıyoruz.
            patternInput.text = ""
            Qt.callLater(function() {
                dumPattern = []
                beatValues = []
                patternRepeater.model = 0
            })
        }
    }

    function tickToLetter(t) {
        if (t === 960 || t === 1440) return "i"
        if (t === 480 || t === 720)  return "d"
        if (t === 240 || t === 360)  return "s"
        if (t === 120 || t === 180)  return "o"
        return "?"
    }

    function calcTimeSig() {
        var has16 = false, has8 = false, hasDot8 = false, hasDot4 = false
        for (var i = 0; i < beatValues.length; i++) {
            var t = beatValues[i]
            if (t <= 120)  has16 = true
            if (t === 240) has8 = true
            if (t === 360 || t === 180) hasDot8 = true
            if (t === 720 || t === 1440) hasDot4 = true
        }
        var denom, REF
        if (has16 || hasDot8) { denom = 16; REF = 120 }
        else if (has8 || hasDot4) { denom = 8; REF = 240 }
        else { denom = 4; REF = 480 }
        var num = 0
        for (var j = 0; j < beatValues.length; j++) num += Math.round(beatValues[j] / REF)
        return { num: num, denom: denom }
    }

    function parsePattern(text) {
        var TICKS = { "i": 960, "i.": 1440, "d": 480, "d.": 720,
                      "s": 240, "s.": 360, "o": 120, "o.": 180 }
        var MAX_BEATS = 16  // İzin verilen maksimum vuruş sayısı

        // Art arda + ve boşlukları tek ayraç gibi yorumla (örn. "s+++d" → "s+d")
        var tokens = text.trim().replace(/\++/g, " ").split(/\s+/).filter(function(x){return x.length > 0})
        if (tokens.length === 0 || (tokens.length === 1 && tokens[0] === "")) {
            statusLabel.text = ""  // Boş bırakılınca hata mesajını temizle
            return false
        }
        var vals = []
        for (var i = 0; i < tokens.length; i++) {
            var t = tokens[i].toLowerCase().trim()
            if (t === "") continue
            if (TICKS[t] === undefined) {
                statusLabel.text = "Hata: \"" + t + "\" geçersiz. Sadece i, d, s, o harfleri ve nokta (.) kullanın. Örn: i+d+d"
                return false
            }
            vals.push(TICKS[t])
        }
        if (vals.length === 0) return false

        // 20 vuruş sınırı: fazlası kesilir, kutucuk güncellenir, uyarı gösterilir
        if (vals.length > MAX_BEATS) {
            vals = vals.slice(0, MAX_BEATS)
            var trimmedTokens = tokens.slice(0, MAX_BEATS)

            beatValues = vals
            var newDumTrim = []
            for (var k = 0; k < vals.length; k++) newDumTrim.push(dumPattern[k] === true)
            dumPattern = newDumTrim
            patternRepeater.model = 0
            patternRepeater.model = vals.length

            // Metin kutusunu güncellemeyi bir sonraki event loop turuna ertele.
            // Aksi halde onTextChanged içinden tekrar text değiştirmek
            // özyinelemeli tetiklenmeye yol açıp arayüzü kilitleyebilir.
            Qt.callLater(function() {
                patternInput.text = trimmedTokens.join("+")
                statusLabel.text = "Uyarı: En fazla 16 vuruş girilebilir. Fazla vuruşlar silindi."
            })

            return true
        }

        beatValues = vals
        var newDum = []
        for (var j = 0; j < vals.length; j++) newDum.push(dumPattern[j] === true)
        dumPattern = newDum
        patternRepeater.model = 0
        patternRepeater.model = vals.length
        // Desen geçerliyse önceki hata mesajını temizle
        statusLabel.text = ""
        return true
    }

    // ADIM D: ADIM C + nota yazma döngüsü (TAM VERSİYON)

    function createUsulPart() {
        if (typeof curScore === "undefined" || curScore === null) {
            statusLabel.text = "Açık bir nota bulunamadı."
            return
        }

        if (!parsePattern(patternInput.text)) {
            statusLabel.text = "Hata: Geçersiz format."
            return
        }

        // Usul adını belirle: "Diğer" seçiliyse elle girilen ad, değilse şablon adı kullanılır.
        // Şablon adındaki "N Zamanlı — " ön ekini StaffText'te tekrar etmemek için ayıklıyoruz.
        var usulName
        var isOtherSelected = (usulPresetCombo.currentIndex === usulPresets.length - 1)
        if (isOtherSelected) {
            usulName = usulNameField.text.trim()
            if (usulName.length === 0) usulName = "Usul"
        } else {
            var fullPresetName = usulPresets[usulPresetCombo.currentIndex].name
            var dashIndex = fullPresetName.indexOf("—")
            usulName = dashIndex >= 0 ? fullPresetName.substring(dashIndex + 1).trim() : fullPresetName
        }

        var beatCount = beatValues.length
        var startTick = 0

        var startCursor = curScore.newCursor()
        startCursor.rewind(Cursor.SELECTION_START)
        if (startCursor.segment) {
            startTick = startCursor.tick
        } else {
            startCursor.rewind(Cursor.SCORE_START)
            startTick = startCursor.tick
        }

        var sig = calcTimeSig()
        curScore.startCmd()
        var ts = newElement(Element.TIMESIG)
        ts.timesig = fraction(sig.num, sig.denom)
        var tsCursor = curScore.newCursor()
        tsCursor.rewindToTick(startTick)
        tsCursor.add(ts)
        curScore.endCmd()

        curScore.startCmd()
        curScore.appendPart("drumset")
        curScore.endCmd()

        var staffIdx = curScore.nstaves - 1
        var totalMeasures = curScore.nmeasures
        var track = staffIdx * 4

        var startMeasure = curScore.firstMeasure
        var mm = startMeasure
        while (mm && mm.nextMeasure && mm.firstSegment.tick < startTick) {
            mm = mm.nextMeasure
        }
        startMeasure = mm

        curScore.startCmd()

        var stc = curScore.newCursor()
        stc.track = track
        stc.rewindToTick(startMeasure.firstSegment.tick)
        var st = newElement(Element.STAFF_TEXT)
        st.text = usulName
        stc.add(st)

        var measureCount = 0
        var measure = startMeasure

        // Tek cursor, tek voice — her ölçünün başında rewindToTick ile konumlandırılır.
        // Her vuruştan sonra currentTick tick değeriyle ilerler.
        // Kuvvetli notalar sap yukarı (Direction.UP), zayıf notalar sap aşağı (Direction.DOWN).
        var cur = curScore.newCursor()
        cur.track = track
        cur.voice = 0

        while (measure && measureCount < totalMeasures) {
            var currentTick = measure.firstSegment.tick
            cur.rewindToTick(currentTick)

            for (var b = 0; b < beatCount; b++) {
                var isStrong = (dumPattern.length > b) ? dumPattern[b] === true : false
                var tck = beatValues[b]
                var isDoTed = (tck === 1440 || tck === 720 || tck === 360 || tck === 180)

                cur.rewindToTick(currentTick)

                if (isDoTed) {
                    var nd = 0
                    if      (tck === 720)  nd = 8
                    else if (tck === 360)  nd = 16
                    else if (tck === 1440) nd = 4
                    else if (tck === 180)  nd = 32
                    cur.setDuration(3, nd)
                } else {
                    var denom = Math.round(1920 / tck)
                    cur.setDuration(1, denom)
                }
                cur.addNote(isStrong ? dumPitch : tekPitch, false)

                currentTick += tck
            }

            measure = measure.nextMeasure
            measureCount++
        }

        curScore.endCmd()

        // Doğru API: Beam.NONE (BeamMode değil, Beam nesnesi)
        // Her chord için beamMode = Beam.NONE → kirişsiz nota
        // stemDirection: dumPitch=UP, tekPitch=DOWN
        curScore.startCmd()
        var fixCur = curScore.newCursor()
        fixCur.track = track
        fixCur.rewindToTick(startMeasure.firstSegment.tick)

        while (fixCur.segment) {
            if (fixCur.element && fixCur.element.type === Element.CHORD) {
                fixCur.element.beamMode = Beam.NONE
                var isS = (fixCur.element.notes.length > 0 &&
                           fixCur.element.notes[0].pitch === dumPitch)
                fixCur.element.stemDirection = isS ? 1 : 2
            }
            fixCur.next()
        }
        curScore.endCmd()

        // Oluşturulan davul partisini baştan sona seç
        var lastMeasure = curScore.lastMeasure
        curScore.selection.selectRange(
            startMeasure.firstSegment.tick,
            lastMeasure.lastSegment.tick + 1,
            staffIdx, staffIdx + 1
        )

        statusLabel.text = "✓ Parti oluşturuldu."
    }

    Rectangle {
        anchors.fill: parent
        color: "#d9d9d9"

        ColumnLayout {
            // anchors.fill yerine top+left+right kullanıyoruz; böylece bileşenler
            // gizlendiğinde (visible: false) kalan içerik boşluğa yayılmaz,
            // her zaman üstten başlayarak art arda dizilir.
            anchors.top: parent.top
            anchors.left: parent.left
            anchors.right: parent.right
            anchors.margins: 14
            spacing: 7

            Label {
                Layout.fillWidth: true
                Layout.maximumWidth: 420
                wrapMode: Text.WordWrap
                text: "1 - İstediğiniz usulü listeden seçin ya da \"Diğer\" seçeneğiyle elle girin. Seçilen usul adı dizeğin üstüne metin olarak eklenecektir."
                font.bold: true
                color: "black"
            }

            // Hazır usul şablonları açılır listesi
            ComboBox {
                id: usulPresetCombo
                Layout.fillWidth: true
                currentIndex: 2  // varsayılan: 4 Zamanlı — Sofyan

                // ListModel + ListElement: MuseScore/Qt'nin ComboBox için
                // güvenilir desteklediği model türü. Düz JS dizisi (property var)
                // textRole ile birlikte boş liste sorununa yol açabiliyor.
                model: ListModel {
                    ListElement { text: "2 Zamanlı — Nim Sofyan" }
                    ListElement { text: "3 Zamanlı — Semai" }
                    ListElement { text: "4 Zamanlı — Sofyan" }
                    ListElement { text: "5 Zamanlı — Türk Aksağı (2+3)" }
                    ListElement { text: "5 Zamanlı — Türk Aksağı (3+2)" }
                    ListElement { text: "6 Zamanlı — Yürük Semai" }
                    ListElement { text: "7 Zamanlı — Devr-i Hindi (3+2+2)" }
                    ListElement { text: "7 Zamanlı — Devr-i Turan (2+2+3)" }
                    ListElement { text: "8 Zamanlı — Düyek" }
                    ListElement { text: "8 Zamanlı — Müsemmen" }
                    ListElement { text: "9 Zamanlı — Aksak" }
                    ListElement { text: "9 Zamanlı — Evfer" }
                    ListElement { text: "9 Zamanlı — Raks Aksağı" }
                    ListElement { text: "9 Zamanlı — Oynak" }
                    ListElement { text: "10 Zamanlı — Aksak Semai" }
                    ListElement { text: "10 Zamanlı — Curcuna" }
                    ListElement { text: "10 Zamanlı — Cengi Harbi" }
                    ListElement { text: "Diğer (Elle Gir)" }
                }

                onCurrentIndexChanged: applyPreset(currentIndex)

                // Eklenti ilk açıldığında varsayılan seçili şablonu (Sofyan) hemen uygula.
                // onCurrentIndexChanged, currentIndex zaten başlangıç değerinde olduğu için
                // component yüklenirken tetiklenmiyor; bu yüzden ayrıca burada çağırıyoruz.
                Component.onCompleted: applyPreset(currentIndex)
            }

            // Seçili usul şablonunun vuruş şeması: iki çizgi (üst=kuvvetli/sağ el,
            // alt=zayıf/sol el), düm/tek heceleri ile gösterilir.
            // "Diğer" seçiliyken (svgKey boş) gizli kalır.
            Image {
                Layout.fillWidth: true
                Layout.preferredHeight: 150
                fillMode: Image.PreserveAspectFit
                visible: usulPresets[usulPresetCombo.currentIndex].svgKey.length > 0
                source: {
                    var key = usulPresets[usulPresetCombo.currentIndex].svgKey
                    if (key.length === 0) return ""
                    return "data:image/svg+xml;base64," + usulSvgMap[key]
                }
            }

            // "Diğer" seçiliyse: kullanıcı kendi usul adını yazabilsin
            TextField {
                id: usulNameField
                Layout.fillWidth: true
                visible: usulPresetCombo.currentIndex === usulPresets.length - 1
                placeholderText: "Usul adını yazın (Örn. Hafif, Çenber...)"
                color: "black"
                background: Rectangle { color: "white"; border.color: "#aaa"; radius: 3 }
            }

            Label {
                Layout.fillWidth: true
                Layout.maximumWidth: 420
                wrapMode: Text.WordWrap
                text: "2 - Usul'ün ritmini harflerin arasına \"+\" (artı) işaretini girerek yazın. İkilik nota için (i), dörtlük nota için (d), sekizlik nota için (s) onaltılık nota için de (o) harflerini kullanın. Noktalı notalar için harfin yanına \".\" nokta koyun (d. gibi). Örneğin Semai usulü için \"d+d+d\", Sofyan usulü için \"i+d+d\", Düyek usulü için \"s+d+s+d+d\" ya da Türk Halk Müziği 7/8'lik usulü için \"d+d+d.\" yazın. En az 2, en fazla 16 zamanlı usul yapabilirsiniz."
                font.bold: true
                color: "black"
                // Sadece "Diğer" seçiliyken bu açıklama gösterilir
                visible: usulPresetCombo.currentIndex === usulPresetCombo.count - 1
            }


            RowLayout {
                spacing: 8
                // Sadece "Diğer" seçiliyken bu satır (desen girişi + zaman imzası) gösterilir
                visible: usulPresetCombo.currentIndex === usulPresetCombo.count - 1
                TextField {
                    id: patternInput
                    Layout.fillWidth: true
                    text: "d+d+d+d"
                    placeholderText: "Örn: i+d+d  veya  s+s+s+s+s+s+s+s+s"
                    onTextChanged: parsePattern(text)
                    color: "black"
                    // Sadece "Diğer" seçiliyken düzenlenebilir; hazır şablonlarda içerik görünür ama salt okunur
                    enabled: usulPresetCombo.currentIndex === usulPresetCombo.count - 1
                    // Geçersiz karakter içeriyorsa kenarlık kırmızı olur
                    property bool hasInvalidChar: /[^idso.+]/i.test(text)
                    background: Rectangle {
                        color: patternInput.enabled ? "white" : "#eeeeee"
                        border.color: patternInput.hasInvalidChar ? "#c0392b" : "#aaa"
                        border.width: patternInput.hasInvalidChar ? 2 : 1
                        radius: 3
                    }
                }
                Label {
                    text: {
                        var sig = calcTimeSig()
                        return sig.num + "/" + sig.denom
                    }
                    font.bold: true
                    font.pixelSize: 18
                    color: "#c0392b"
                    // beatValues boşsa (örn. "Diğer" yeni seçilmiş, henüz yazı girilmemiş) gizli kalır
                    visible: beatValues.length > 0
                }
            }

            Label {
                Layout.fillWidth: true
                Layout.maximumWidth: 420
                wrapMode: Text.WordWrap
                text: "3 - Kuvvetli olmasını istediğiniz nota için kutucuğu işaretleyin, işaretsiz bırakılanlar zayıf olarak çalınacaktır."
                font.bold: true
                color: "black"
                // "Diğer" seçiliyken VE metin kutusu doluyken görünür
                visible: usulPresetCombo.currentIndex === usulPresetCombo.count - 1 && beatValues.length > 0
            }

            Flow {
                id: patternFlow
                Layout.fillWidth: true
                spacing: 4
                // "Diğer" seçiliyken VE desen girilmişse checkbox satırı görünür
                visible: usulPresetCombo.currentIndex === usulPresetCombo.count - 1 && beatValues.length > 0

                Repeater {
                    id: patternRepeater
                    model: 4

                    delegate: RowLayout {
                        spacing: 4
                        ColumnLayout {
                            spacing: 2
                            Label {
                                text: beatValues.length > index ? tickToLetter(beatValues[index]) : "?"
                                Layout.alignment: Qt.AlignHCenter
                                font.pixelSize: 13
                                font.bold: true
                                color: "#c0392b"
                            }
                            CheckBox {
                                id: beatCheckBox
                                checked: dumPattern.length > index ? dumPattern[index] === true : false
                                // Sadece "Diğer" seçiliyken kullanıcı işaretleyebilir; hazır şablonlarda salt görünür
                                enabled: usulPresetCombo.currentIndex === usulPresetCombo.count - 1
                                onToggled: {
                                    var arr = dumPattern.slice()
                                    while (arr.length <= index) arr.push(false)
                                    arr[index] = checked
                                    dumPattern = arr
                                }
                                // Pasif durumda bile kutu çerçevesi ve işareti net görünsün
                                // (varsayılan stil, disabled iken soluklaştırıp kayboluyordu)
                                indicator: Rectangle {
                                    implicitWidth: 18
                                    implicitHeight: 18
                                    x: beatCheckBox.leftPadding
                                    y: parent.height / 2 - height / 2
                                    radius: 3
                                    border.color: "#333333"
                                    border.width: 1.5
                                    color: beatCheckBox.enabled ? "white" : "#e0e0e0"

                                    Rectangle {
                                        visible: beatCheckBox.checked
                                        anchors.centerIn: parent
                                        width: 10
                                        height: 10
                                        radius: 2
                                        color: "black"
                                    }
                                }
                            }
                        }
                        Label {
                            text: "+"
                            font.pixelSize: 14
                            font.bold: true
                            color: "black"
                            visible: index < patternRepeater.model - 1
                        }
                    }
                }
            }

        }

        // Alt blok: durum mesajı, butonlar ve geliştiren bilgisi.
        // Üstteki ColumnLayout'tan ayrı tutulup pencerenin altına sabitlendi;
        // böylece içerik (hazır şablon / "Diğer") değişse de bu blok yer değiştirmez.
        ColumnLayout {
            anchors.bottom: parent.bottom
            anchors.left: parent.left
            anchors.right: parent.right
            anchors.margins: 14
            anchors.bottomMargin: 10
            spacing: 6

            Label {
                id: statusLabel
                text: ""
                color: "black"
                wrapMode: Text.WordWrap
                Layout.fillWidth: true
                font.pixelSize: 11
            }

            RowLayout {
                Layout.alignment: Qt.AlignRight
                spacing: 8
                Button {
                    text: "Kapat"
                    onClicked: usulPlugin.parent.Window.window.close()
                }
                Button {
                    id: olusturBtn
                    text: "Oluştur"
                    highlighted: true
                    onClicked: createUsulPart()
                }
